# MOCK/DEVELOPMENT MODE
# Set to "true" to test without physical hardware (camera, GPIO, sensors)
MOCK_MODE=false

# Set to "true" to use fswebcam for VM testing with USB camera
# Only used when MOCK_MODE=true
USE_FSWEBCAM=false

# CLOUDINARY CONFIGURATION
# Get these from https://cloudinary.com/console
# NOTE: Some Cloudinary SDKs use CLOUDINARY_URL, others use individual variables.
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_URL=cloudinary://your_api_key_here:your_api_secret_here@your_cloud_name_here

# BACKEND SERVER URL
# Example: https://your-server.com/api/
SERVER_URL=https://your-server.com/api/

# SENSOR API KEY AUTH
# Must match IOT_API_KEY configured in agos-backend
IOT_API_KEY=rpi_api_key_here

# WEBSOCKET SERVER URL
WEBSOCKET_SERVER_URL=wss://your-server.com/ws/stream

# WEBSOCKET KEEPALIVE (Optional)
# Set WS_PING_INTERVAL=0 to disable client pings if the server is busy.
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=20
WS_CLOSE_TIMEOUT=10

# Feature toggles
# Set to "true" to enable uploading images to Cloudinary
ENABLE_CLOUDINARY_UPLOAD=true
# Set to "true" to enable sending data via WebSocket
ENABLE_WEBSOCKET_SEND=true
# Set to "true" to send a JSON metadata frame before each binary image frame.
# Keep false if your backend expects binary-only frames (same behavior as ws_sender.py).
WS_SEND_METADATA_FIRST=false
# Set to "true" to use pre-captured test images from TEST_IMAGES_DIR
# (works independently of MOCK_MODE test image generation)
USE_TEST_IMAGES=false
# Directory path (relative to project root) containing test images
TEST_IMAGES_DIR=test_images
# Set to false to skip sensor POSTs and only print local sensor logs (useful when API is rate-limited).
SENSOR_POST_ENABLED=true

# TIMING / THROUGHPUT
# SENSOR_INTERVAL — seconds between JSN-SR04 reads and server POSTs.
#   1.0  = 1 reading/second  (default, matches JSN-SR04 60ms cycle easily)
#   0.5  = 2 readings/second

SENSOR_INTERVAL=1.0
CAMERA_INTERVAL=0.5
# JSN-SR04 sensor GPIO pins (BCM numbering)
SENSOR_TRIG_PIN=23
SENSOR_ECHO_PIN=24
CAMERA_DEVICE_ID = 1
LOCATION_ID = 1

# SENSOR FILTER (outlier rejection + smoothing)
#
# LED CONTROL POLLING (optional)
# If set, the device will poll this URL every LED_CONTROL_POLL_INTERVAL seconds
# to fetch the desired LED color/state from the backend. Leave blank to disable.
LED_CONTROL_POLL_URL=
# How often (in seconds) to poll the backend for LED state (e.g., 180 = every 3 minutes)
LED_CONTROL_POLL_INTERVAL=180

SENSOR_FILTER_ENABLED=true
SENSOR_FILTER_WINDOW_SIZE=7
SENSOR_FILTER_MIN_VALID_SAMPLES=3
SENSOR_FILTER_MIN_CM=0.0
SENSOR_FILTER_MAX_CM=400.0
SENSOR_FILTER_MODZ_THRESHOLD=3.5
SENSOR_FILTER_ZERO_MAD_TOLERANCE_CM=1.0

# Rebaseline after this many consecutive outlier rejections (handles true level shifts).
SENSOR_FILTER_REBASELINE_OUTLIER_STREAK=5

# Only rebaseline when the consecutive outlier streak is internally consistent.
# Lower value = stricter (fewer false shifts), higher value = easier adaptation.
SENSOR_FILTER_REBASELINE_SPREAD_MAX_CM=8.0

# FRAME QUALITY GATE (lightweight OpenCV pre-check)
# Reject unusable frames before upload/WebSocket send.
FRAME_QUALITY_CHECK_ENABLED=true
FRAME_QUALITY_MIN_BRIGHTNESS=25.0
FRAME_QUALITY_MAX_BRIGHTNESS=230.0
FRAME_QUALITY_MIN_CONTRAST_STDDEV=10.0
FRAME_QUALITY_MIN_LAPLACIAN_VAR=80.0
FRAME_QUALITY_RESIZE_WIDTH=320

# CAMERA RESOLUTION & SENSOR CROP (Optional)

# CAMERA_WIDTH=1920
# CAMERA_HEIGHT=1080
# CAMERA_NO_CROP=false
# CAMERA_SENSOR_WIDTH=2592
# CAMERA_SENSOR_HEIGHT=1944

# IR-CUT FILTER

# The mode is set automatically at startup based on the system clock (06:00–18:00 = day).
# Set to -1 to disable IR-CUT control entirely (e.g. standard camera module).
# IR_CUT_PIN=17
# IR_CUT_MODE=auto          # auto | day | night
# IR_CUT_DAY_START_HOUR=6
# IR_CUT_NIGHT_START_HOUR=18
# IR_CUT_MIN_SWITCH_INTERVAL_S=30
# IR_CUT_DAY_HIGH=true      # true means GPIO HIGH=day mode, LOW=night mode
#
# Note: On many IR-CUT camera boards, the IR LED boards are auto-controlled on
# the camera hardware and powered from CSI/board power. This project controls
# only the IR-CUT switch pin, not LED brightness/state.

# DEVICE IDENTIFICATION (Optional)
#Sensor device ID (must match the device registered in the backend)
SENSOR_DEVICE_ID=1

# LOCAL LED WARNING
# Set true to light an LED when water level reaches/exceeds threshold.
LED_WARNING_ENABLED=false
# BCM pin connected to LED (use a resistor in series).
LED_WARNING_PIN=14
# Warning threshold in cm.
LED_WARNING_THRESHOLD_CM=10.0

# LOCAL LED CLEAR (green, optional)
# LED_CLEAR_ENABLED controls the green safe-state LED on LED_CLEAR_PIN.
# Current code does NOT read LED_CLEAR_THRESHOLD_CM; clear logic uses LED_WARNING_THRESHOLD_CM.
# Behavior with current implementation:
# - If LED_CLEAR_ENABLED=true, clear LED is ON when level > LED_WARNING_THRESHOLD_CM.
# - If LED_WARNING_ENABLED=true, warning LED is ON when level <= LED_WARNING_THRESHOLD_CM.
# - If LED_CLEAR_ENABLED=true and LED_WARNING_ENABLED=false, clear LED still uses
#   LED_WARNING_THRESHOLD_CM and works independently of warning LED output.
# LED_CLEAR_THRESHOLD_CM is listed here for discoverability/future extension only.
LED_CLEAR_ENABLED=true
# BCM pin connected to green LED (use a resistor in series).
LED_CLEAR_PIN=15
# LED_CLEAR_THRESHOLD_CM=10.0

# MOCK MODE USAGE INSTRUCTIONS
# For development without hardware:
# 1. Set MOCK_MODE=true
# 2. Camera will use one of these (in order):
#    - fswebcam (if USE_FSWEBCAM=true and installed)
#    - test_image.jpg (if file exists in project root)
#    - Generated test image with timestamp
# 3. Sensor will return randomized water levels (5-25 cm)
# 4. No GPIO initialization will occur
#
# For VM testing with USB camera:
# 1. Set MOCK_MODE=true
# 2. Set USE_FSWEBCAM=true
# 3. Install fswebcam: sudo apt-get install fswebcam
# 4. Connect USB camera to VM
#
# For production deployment:
# 1. Set MOCK_MODE=false
# 2. Set USE_FSWEBCAM=false
# 3. Ensure Raspberry Pi Camera and GPIO sensors are connected
