# ==========================================
# SYSTEM CORE
# ==========================================
# Example: https://your-server.com/api/v1/sensor-readings/record
SERVER_URL=http://192.168.1.14:8000/api/v1/sensor-readings/record
# Example: wss://your-server.com/ws/rpi?camera_device_id=1&location_id=1
WEBSOCKET_SERVER_URL=ws://192.168.1.14:8000/ws/rpi?camera_device_id=1&location_id=1
IOT_API_KEY=your_api_key_here

SENSOR_DEVICE_ID=1
CAMERA_DEVICE_ID=1
LOCATION_ID=1

# ==========================================
# TIMING / THROUGHPUT
# ==========================================
# SENSOR_INTERVAL — seconds between JSN-SR04 reads and server POSTs.
SENSOR_INTERVAL=1.0
# CAMERA_INTERVAL — seconds between camera frames
CAMERA_INTERVAL=2.0

# ==========================================
# CLOUDINARY CONFIGURATION
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_URL=cloudinary://your_api_key_here:your_api_secret_here@your_cloud_name_here

# ==========================================
# FEATURE TOGGLES
# ==========================================
ENABLE_CLOUDINARY_UPLOAD=false
ENABLE_WEBSOCKET_SEND=true
WS_SEND_METADATA_FIRST=false
SENSOR_POST_ENABLED=true

# MOCK/DEVELOPMENT MODE
# Set MOCK_MODE=true to test without physical hardware (camera, GPIO, sensors)
MOCK_MODE=false
# Set USE_FSWEBCAM=true to use fswebcam for VM testing with USB camera (only when MOCK_MODE=true)
USE_FSWEBCAM=false
# Set USE_TEST_IMAGES=true to use static test images
USE_TEST_IMAGES=false
TEST_IMAGES_DIR=test_images

# ==========================================
# WEBSOCKET KEEPALIVE
# ==========================================
# Set WS_PING_INTERVAL=0 to disable client pings if the server is busy.
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=30
WS_CLOSE_TIMEOUT=10

# ==========================================
# LOCAL LED INDICATORS
# ==========================================
LED_WARNING_ENABLED=true
LED_WARNING_PIN=14
LED_WARNING_THRESHOLD_CM=30.0

LED_CLEAR_ENABLED=true
LED_CLEAR_PIN=15

# ==========================================
# SENSOR HARDWARE & FILTERING
# ==========================================
SENSOR_TRIG_PIN=23
SENSOR_ECHO_PIN=24

# SENSOR FILTER (outlier rejection + smoothing)
SENSOR_FILTER_ENABLED=true
SENSOR_FILTER_WINDOW_SIZE=7
SENSOR_FILTER_MIN_VALID_SAMPLES=3
SENSOR_FILTER_MIN_CM=0.0
SENSOR_FILTER_MAX_CM=400.0
SENSOR_FILTER_MODZ_THRESHOLD=3.5
SENSOR_FILTER_ZERO_MAD_TOLERANCE_CM=1.0
SENSOR_FILTER_REBASELINE_OUTLIER_STREAK=5
SENSOR_FILTER_REBASELINE_SPREAD_MAX_CM=8.0

# ==========================================
# FRAME QUALITY GATE
# Reject unusable frames before upload/WebSocket send.
# Tuned for YOLOv8 detection accuracy on OV5647
# ==========================================
FRAME_QUALITY_CHECK_ENABLED=true
FRAME_QUALITY_MIN_BRIGHTNESS=45.0
FRAME_QUALITY_MAX_BRIGHTNESS=210.0
FRAME_QUALITY_MIN_CONTRAST_STDDEV=25.0
FRAME_QUALITY_MIN_LAPLACIAN_VAR=100.0
FRAME_QUALITY_RESIZE_WIDTH=320

# ==========================================
# CAMERA SETTINGS (Picamera2 / libcamera)
# ==========================================
# Full sensor resolution (5MP for OV5647)
CAMERA_WIDTH=2592
CAMERA_HEIGHT=1944
CAMERA_NO_CROP=true
# Set true to print runtime ScalerCrop metadata for verification.
CAMERA_LOG_SCALERCROP=true

# Image quality enhancements
CAMERA_JPEG_QUALITY=95
CAMERA_SHARPNESS=1.5
CAMERA_CONTRAST=1.3
CAMERA_SATURATION=1.0

# Tuning files for day and night. 
# Requires files to exist in /usr/share/libcamera/ipa/rpi/vc4/
CAMERA_TUNING_FILE_DAY=ov5647.json
CAMERA_TUNING_FILE_NIGHT=ov5647_noir.json

# EXPOSURE SETTINGS
# Manual exposure (0 = auto, recommended for daytime)
# For strict manual night/IR: try CAMERA_EXPOSURE_TIME=200000 and CAMERA_ANALOGUE_GAIN=4.0
CAMERA_EXPOSURE_TIME=0
CAMERA_ANALOGUE_GAIN=0
# Max frame duration in µs for auto-exposure (500000 = 0.5s)
CAMERA_FRAME_DURATION_MAX=500000

# Exposure compensation: +1.0 = 1 stop brighter, +2.0 = 2 stops brighter
# This forces the auto-exposure to target a brighter image, fixing shadows
# At night, IR glare can cause overexposure, so you may need a negative value (e.g. -2.0)
CAMERA_EXPOSURE_VALUE_DAY=0.0
CAMERA_EXPOSURE_VALUE_NIGHT=0.0

# ==========================================
# IR-CUT FILTER CONTROL
# ==========================================
# The mode is set automatically at startup based on the system clock (06:00–18:00 = day).
# Set IR_CUT_PIN=-1 to disable IR-CUT control entirely (e.g. standard camera module).
IR_CUT_PIN=17
# IR_CUT_MODE: auto | day | night
IR_CUT_MODE=auto
IR_CUT_DAY_START_HOUR=6
IR_CUT_NIGHT_START_HOUR=18
IR_CUT_MIN_SWITCH_INTERVAL_S=30
# true means GPIO HIGH=day mode, LOW=night mode
IR_CUT_DAY_HIGH=true
IR_CUT_TIMEZONE=Asia/Manila
 
# ==========================================
# POST-CAPTURE CROP (Region of Interest)
# ==========================================
# Set to true to crop the image after capture
IMAGE_CROP_ENABLED=false
# Crop coordinates (X, Y, Width, Height) based on 2592x1944
IMAGE_CROP_X=518
IMAGE_CROP_Y=777
IMAGE_CROP_WIDTH=1555
IMAGE_CROP_HEIGHT=972